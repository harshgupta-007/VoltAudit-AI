# ==============================================================================
# VoltAudit AI — Local Environment Variables Example
# Copy this file to '.env' and fill in actual values. Do NOT commit '.env' to Git.
# ==============================================================================

# Global Configurations
ENV=development # development | test | production
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR | CRITICAL

# Backend API Configuration
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
SECRET_KEY=replace_this_with_a_secure_jwt_secret_key_at_least_32_bytes_long
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALLOWED_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database Configuration (Development default: SQLite)
DATABASE_URL=sqlite:///./voltaudit.db

# Postgres Database (Production/Staging Example)
# DATABASE_URL=postgresql://db_user:db_password@localhost:5432/voltaudit

# Google Vertex AI / Gemini API Configuration
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-1.5-pro-latest

# Vector Database (Qdrant / PGVector / etc.)
VECTOR_DB_URL=http://localhost:6333
VECTOR_DB_API_KEY=YOUR_VECTOR_DB_API_KEY_HERE

# MCP (Model Context Protocol) Server Configurations
MCP_INVOICE_DB_PORT=8080
MCP_REGULATORY_RULES_PORT=8081

# Security and SSL (Staging/Production Only)
# SSL_CERT_PATH=/etc/ssl/certs/voltaudit.crt
# SSL_KEY_PATH=/etc/ssl/private/voltaudit.key
