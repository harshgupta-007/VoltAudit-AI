<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 900 500" width="100%" height="100%">
  <rect width="100%" height="100%" fill="#0f172a" rx="20" />
  
  <text x="450" y="55" font-family="'Outfit', sans-serif" font-size="24" font-weight="700" fill="#ffffff" text-anchor="middle" letter-spacing="1">MODEL CONTEXT PROTOCOL (MCP) ISOLATION BOUNDARY</text>
  
  <!-- Outer containers -->
  <!-- Left Side: Unsecured AI Execution Realm -->
  <g transform="translate(80, 100)">
    <rect width="320" height="320" fill="#0b0f19" stroke="#ef4444" stroke-width="2" rx="10" />
    <text x="160" y="-15" font-family="'Outfit', sans-serif" font-size="14" font-weight="700" fill="#ef4444" text-anchor="middle">UNTRUSTED AGENT EXECUTION ZONE</text>
    
    <!-- User Input Invoice -->
    <g transform="translate(30, 40)">
      <rect width="260" height="50" fill="#1e293b" stroke="#334155" rx="5" />
      <text x="130" y="30" font-family="'Outfit', sans-serif" font-size="12" font-weight="700" fill="#ffffff" text-anchor="middle">Hostile Input Document (PDF/Text)</text>
    </g>

    <!-- LLM reasoning loop -->
    <g transform="translate(30, 140)">
      <rect width="260" height="50" fill="#1e293b" stroke="#334155" rx="5" />
      <text x="130" y="30" font-family="'Outfit', sans-serif" font-size="12" font-weight="700" fill="#ffffff" text-anchor="middle">Gemini LLM Reasoning Loop</text>
    </g>

    <!-- ADK Agents -->
    <g transform="translate(30, 240)">
      <rect width="260" height="50" fill="#1e293b" stroke="#334155" rx="5" />
      <text x="130" y="30" font-family="'Outfit', sans-serif" font-size="12" font-weight="700" fill="#ffffff" text-anchor="middle">ADK Specialist Agents</text>
    </g>
  </g>

  <!-- Right Side: Secured Database Realm -->
  <g transform="translate(500, 100)">
    <rect width="320" height="320" fill="#0b0f19" stroke="#10b981" stroke-width="2" rx="10" />
    <text x="160" y="-15" font-family="'Outfit', sans-serif" font-size="14" font-weight="700" fill="#10b981" text-anchor="middle">SECURED ENTERPRISE DATABASE ZONE</text>
    
    <!-- FastMCP Server -->
    <g transform="translate(30, 80)">
      <rect width="260" height="60" fill="#0f172a" stroke="#10b981" stroke-width="2" rx="5" />
      <text x="130" y="27" font-family="'Outfit', sans-serif" font-size="12" font-weight="700" fill="#ffffff" text-anchor="middle">FastMCP Server</text>
      <text x="130" y="45" font-family="'Outfit', sans-serif" font-size="10" fill="#94a3b8" text-anchor="middle">Exposes pre-parameterized tools</text>
    </g>

    <!-- SQLite DB -->
    <g transform="translate(60, 200)">
      <rect width="200" height="80" fill="#1e293b" stroke="#3b82f6" stroke-width="2" rx="10" />
      <text x="100" y="35" font-family="'Outfit', sans-serif" font-size="14" font-weight="700" fill="#ffffff" text-anchor="middle">SQLite Database</text>
      <text x="100" y="55" font-family="'Outfit', sans-serif" font-size="10" fill="#94a3b8" text-anchor="middle">Canonical suppliers, contract logs</text>
    </g>
  </g>

  <!-- The Bounded Gateway Connector -->
  <g transform="translate(400, 230)">
    <line x1="0" y1="0" x2="100" y2="0" stroke="#3b82f6" stroke-width="4" />
    <text x="50" y="-10" font-family="'Outfit', sans-serif" font-size="12" font-weight="700" fill="#3b82f6" text-anchor="middle">MCP PROTOCOL</text>
  </g>
</svg>
