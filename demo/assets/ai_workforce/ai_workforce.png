<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 650" width="100%" height="100%">
  <rect width="100%" height="100%" fill="#0f172a" rx="20" />
  
  <text x="500" y="55" font-family="'Outfit', sans-serif" font-size="26" font-weight="700" fill="#ffffff" text-anchor="middle" letter-spacing="1">AI WORKFORCE HIERARCHY &amp; LIFE-CYCLE FLOW</text>
  
  <!-- Boxes -->
  <!-- Human Supervisor -->
  <g transform="translate(380, 100)">
    <rect width="240" height="60" fill="#ff9800" stroke="#f57c00" stroke-width="2" rx="10" />
    <text x="120" y="35" font-family="'Outfit', sans-serif" font-size="14" font-weight="700" fill="#0f172a" text-anchor="middle">HUMAN AUDIT SUPERVISOR</text>
  </g>
  
  <!-- Executive Coordinator WRK-001 -->
  <g transform="translate(380, 220)">
    <rect width="240" height="60" fill="#1e293b" stroke="#3b82f6" stroke-width="2" rx="10" />
    <text x="120" y="27" font-family="'Outfit', sans-serif" font-size="14" font-weight="700" fill="#ffffff" text-anchor="middle">EXECUTIVE COORDINATOR</text>
    <text x="120" y="47" font-family="'Outfit', sans-serif" font-size="11" font-weight="500" fill="#94a3b8" text-anchor="middle">WRK-001 (Supervisor)</text>
  </g>

  <!-- Specialist subgraph boxes -->
  <g transform="translate(100, 340)">
    <rect width="800" height="220" fill="#0b0f19" stroke="#1e293b" stroke-width="2" rx="15" />
    <text x="400" y="-15" font-family="'Outfit', sans-serif" font-size="14" font-weight="700" fill="#64748b" text-anchor="middle">SPECIALIST AUDIT WORKERS</text>
    
    <!-- Ingest WRK-002 -->
    <g transform="translate(30, 40)">
      <rect width="220" height="50" fill="#1e293b" rx="5" />
      <text x="110" y="24" font-family="'Outfit', sans-serif" font-size="12" font-weight="700" fill="#ffffff" text-anchor="middle">Ingestion Specialist</text>
      <text x="110" y="40" font-family="'Outfit', sans-serif" font-size="10" fill="#94a3b8" text-anchor="middle">WRK-002</text>
    </g>

    <!-- Vendor matching WRK-003 -->
    <g transform="translate(280, 40)">
      <rect width="220" height="50" fill="#1e293b" rx="5" />
      <text x="110" y="24" font-family="'Outfit', sans-serif" font-size="12" font-weight="700" fill="#ffffff" text-anchor="middle">Vendor &amp; Contract Matcher</text>
      <text x="110" y="40" font-family="'Outfit', sans-serif" font-size="10" fill="#94a3b8" text-anchor="middle">WRK-003</text>
    </g>

    <!-- Tariff validation WRK-005 -->
    <g transform="translate(540, 40)">
      <rect width="220" height="50" fill="#1e293b" rx="5" />
      <text x="110" y="24" font-family="'Outfit', sans-serif" font-size="12" font-weight="700" fill="#ffffff" text-anchor="middle">Tariff Auditor</text>
      <text x="110" y="40" font-family="'Outfit', sans-serif" font-size="10" fill="#94a3b8" text-anchor="middle">WRK-005</text>
    </g>

    <!-- Billing math reconciler WRK-006 -->
    <g transform="translate(30, 130)">
      <rect width="220" height="50" fill="#1e293b" rx="5" />
      <text x="110" y="24" font-family="'Outfit', sans-serif" font-size="12" font-weight="700" fill="#ffffff" text-anchor="middle">3-Way Math Reconciler</text>
      <text x="110" y="40" font-family="'Outfit', sans-serif" font-size="10" fill="#94a3b8" text-anchor="middle">WRK-006</text>
    </g>

    <!-- Historical duplicate scan WRK-007 -->
    <g transform="translate(280, 130)">
      <rect width="220" height="50" fill="#1e293b" rx="5" />
      <text x="110" y="24" font-family="'Outfit', sans-serif" font-size="12" font-weight="700" fill="#ffffff" text-anchor="middle">Anomaly Analyst</text>
      <text x="110" y="40" font-family="'Outfit', sans-serif" font-size="10" fill="#94a3b8" text-anchor="middle">WRK-007</text>
    </g>

    <!-- Risk & Reporter WRK-008 -->
    <g transform="translate(540, 130)">
      <rect width="220" height="50" fill="#1e293b" rx="5" />
      <text x="110" y="24" font-family="'Outfit', sans-serif" font-size="12" font-weight="700" fill="#ffffff" text-anchor="middle">Risk &amp; Report Compiler</text>
      <text x="110" y="40" font-family="'Outfit', sans-serif" font-size="10" fill="#94a3b8" text-anchor="middle">WRK-008 / WRK-008_reporter</text>
    </g>
  </g>

  <!-- Connectors -->
  <line x1="500" y1="160" x2="500" y2="220" stroke="#ff9800" stroke-width="2" />
  <line x1="500" y1="280" x2="500" y2="340" stroke="#3b82f6" stroke-width="2" />
</svg>
